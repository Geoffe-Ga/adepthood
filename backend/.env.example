# Example environment variables for backend
DATABASE_URL=postgresql+asyncpg://aptitude:aptitude@localhost:5432/aptitude
SECRET_KEY=replace-me  # REQUIRED: set to a cryptographically random string for JWT signing
ENV=development  # Valid values: development, staging, production
# PROD_DOMAIN=https://app.adepthood.com,https://www.adepthood.com  # REQUIRED in staging/production (comma-separated HTTPS URLs)
